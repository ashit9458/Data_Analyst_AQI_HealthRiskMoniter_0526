Create Table Script
File: sql/create_tables.sql
CREATE TABLE aqi_sensor_data (
    id INT IDENTITY(1,1),
    city VARCHAR(100),
    aqi INT,
    pollutant VARCHAR(50),
    temperature FLOAT,
    humidity FLOAT,
    wind_speed FLOAT,
    reading_time DATETIME
);
